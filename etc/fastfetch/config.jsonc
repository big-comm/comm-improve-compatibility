{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file-raw",
    "source": "/etc/fastfetch/ascii-art",
    "padding": {
      "top": 0,
      "left": 2,
      "right": 2
    }
  },
  "display": {
    "separator": " ",
    "color": {
      "separator": "90",
      "output": "1;37"
    }
  },
  "modules": [
    {
      "type": "title",
      "format": "{user-name-colored}@{host-name-colored}"
    },
    "separator",
    {
      "type": "os",
      "key": "{icon} OS         ",
      "keyColor": "blue",
      "format": "{pretty-name} {arch}"
    },
    {
      "type": "kernel",
      "key": "│ ├ Kernel    ",
      "keyColor": "blue",
      "format": "{release}"
    },
    {
      "type": "uptime",
      "key": "│ ├󰅐 Uptime  ",
      "keyColor": "blue"
    },
    {
      "type": "packages",
      "key": "│ ├󰏖 Packages",
      "keyColor": "blue"
    },
    {
      "type": "shell",
      "key": "│ └ Shell     ",
      "keyColor": "blue"
    },
    {
      "type": "de",
      "key": "󰇄 Desktop    ",
      "keyColor": "cyan"
    },
    {
      "type": "wm",
      "key": "│ ├ WM        ",
      "keyColor": "cyan"
    },
    {
      "type": "theme",
      "key": "│ ├󰉼 Theme    ",
      "keyColor": "cyan"
    },
    {
      "type": "icons",
      "key": "│ ├󰀻 Icons    ",
      "keyColor": "cyan"
    },
    {
      "type": "terminal",
      "key": "│ └ Terminal  ",
      "keyColor": "cyan",
      "format": "{pretty-name} {version}"
    },
    {
      "type": "host",
      "key": "󰌢 Hardware   ",
      "keyColor": "magenta",
      "format": "{name}"
    },
    {
      "type": "cpu",
      "key": "│ ├󰻠 CPU     ",
      "keyColor": "magenta",
      "format": "{name} ({cores-logical}) @ {freq-base}"
    },
    {
      "type": "gpu",
      "key": "│ ├󰍛 GPU     ",
      "keyColor": "magenta"
    },
    {
      "type": "memory",
      "key": "│ ├ RAM       ",
      "keyColor": "magenta"
    },
    {
      "type": "disk",
      "key": "│ ├ Disk      ",
      "keyColor": "magenta",
      "folders": "/"
    },
    {
      "type": "display",
      "key": "│ └󰍹 Display  ",
      "keyColor": "magenta"
    },
    "break",
    {
      "type": "colors",
      "paddingLeft": 2,
      "symbol": "block"
    }
  ]
}
